.page-head {
  padding: 16rpx 4rpx 26rpx;
}

.heading {
  color: #183527;
  font-size: 42rpx;
  font-weight: 800;
}

.subtext {
  margin-top: 8rpx;
  color: #6f7c72;
  font-size: 26rpx;
}

.empty {
  padding: 28rpx 0;
  color: #6f7c72;
  font-size: 28rpx;
  text-align: center;
}

.empty.small {
  padding: 8rpx 0;
  text-align: left;
}

.history-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e3ece4;
  border-radius: 8rpx;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.date {
  color: #183527;
  font-size: 34rpx;
  font-weight: 800;
}

.summary {
  margin-top: 8rpx;
  color: #6f7c72;
  font-size: 24rpx;
}

.expand-text {
  flex-shrink: 0;
  color: #26734d;
  font-size: 26rpx;
}

.metric-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 22rpx;
}

.metric {
  padding: 18rpx;
  background: #f8faf8;
  border: 1rpx solid #edf2ee;
  border-radius: 8rpx;
}

.metric-label {
  display: block;
  color: #6f7c72;
  font-size: 23rpx;
}

.metric-value {
  display: block;
  margin-top: 8rpx;
  color: #1f2d24;
  font-size: 27rpx;
  font-weight: 700;
}

.detail {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #edf2ee;
}

.detail-title {
  margin: 22rpx 0 10rpx;
  color: #183527;
  font-size: 28rpx;
  font-weight: 800;
}

.detail-title:first-child {
  margin-top: 0;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 12rpx 0;
  color: #405247;
  font-size: 26rpx;
  border-bottom: 1rpx solid #f0f4f1;
}

.detail-row text:last-child {
  flex: 1;
  color: #1f2d24;
  text-align: right;
  word-break: break-all;
}

.todo-row {
  padding: 12rpx 0;
  color: #1f2d24;
  font-size: 26rpx;
  word-break: break-all;
}

.todo-done {
  color: #8b9990;
  text-decoration: line-through;
}
