.page-head {
  padding: 16rpx 4rpx 26rpx;
}

.heading {
  color: #183527;
  font-size: 42rpx;
  font-weight: 800;
}

.subtext {
  margin-top: 8rpx;
  color: #6f7c72;
  font-size: 26rpx;
}

.empty {
  padding: 28rpx 0;
  color: #6f7c72;
  font-size: 28rpx;
  text-align: center;
}

.empty.small {
  padding: 8rpx 0;
  text-align: left;
}

.summary-line,
.meal-row {
  display: flex;
  justify-content: space-between;
  gap: 22rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #edf2ee;
  color: #405247;
  font-size: 28rpx;
}

.summary-line text:last-child,
.meal-row text:last-child {
  flex: 1;
  color: #1f2d24;
  text-align: right;
  word-break: break-all;
}

.progress-track {
  height: 16rpx;
  margin: 10rpx 0 14rpx;
  overflow: hidden;
  background: #e7efe9;
  border-radius: 8rpx;
}

.progress-fill {
  height: 100%;
  background: #2e8b57;
  border-radius: 8rpx;
}

.paragraph {
  color: #1f2d24;
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-all;
}

.todo-row {
  padding: 14rpx 0;
  color: #1f2d24;
  font-size: 28rpx;
  word-break: break-all;
}

.todo-done {
  color: #8b9990;
  text-decoration: line-through;
}
