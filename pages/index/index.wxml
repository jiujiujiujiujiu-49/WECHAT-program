<view class="page">
  <view class="hero">
    <view class="title">每日记录</view>
    <view class="subtitle">{{today}} 今日概览</view>
  </view>

  <view class="section" wx:if="{{record}}">
    <view class="section-title">首页</view>
    <view class="overview-grid">
      <view class="overview-card">
        <view class="label">饮水量</view>
        <view class="value">{{record.water.amount}} / {{record.water.target}} ml</view>
      </view>
      <view class="overview-card">
        <view class="label">健身</view>
        <view class="value">{{record.workout.checked ? '已完成' : '未完成'}}</view>
      </view>
      <view class="overview-card">
        <view class="label">学习</view>
        <view class="value">{{record.study.checked ? '已完成' : '未完成'}}</view>
      </view>
      <view class="overview-card">
        <view class="label">睡眠时长</view>
        <view class="value">{{record.sleep.hours}} 小时</view>
      </view>
      <view class="overview-card full">
        <view class="label">待办完成</view>
        <view class="value">{{todoSummary}}</view>
      </view>
    </view>
  </view>
</view>
