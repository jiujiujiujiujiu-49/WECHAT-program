.hero {
  margin-bottom: 24rpx;
  padding: 36rpx 4rpx 18rpx;
}

.title {
  margin-top: 8rpx;
  font-size: 48rpx;
  font-weight: 800;
  color: #183527;
}

.subtitle {
  margin-top: 10rpx;
  color: #6f7c72;
  font-size: 28rpx;
}

.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.overview-card {
  padding: 20rpx;
  background: #f8faf8;
  border: 1rpx solid #e1e9e2;
  border-radius: 8rpx;
}

.overview-card.full {
  grid-column: 1 / -1;
}

.label {
  color: #6f7c72;
  font-size: 24rpx;
}

.value {
  margin-top: 8rpx;
  color: #1e3a2b;
  font-size: 30rpx;
  font-weight: 700;
}
