<view class="page">
  <view class="page-head">
    <view class="heading">Daily To Do List</view>
    <view class="subtext">这里后续新增、勾选和删除今日任务。</view>
  </view>

  <view class="section">
    <view class="section-title">待办占位</view>
    <view class="todo-item" wx:for="{{examples}}" wx:key="*this">
      <checkbox disabled="true" />
      <text class="todo-text">{{item}}</text>
    </view>
  </view>
</view>
