page {
  min-height: 100vh;
  background: #f4f7f4;
  color: #1f2d24;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

view,
text,
input,
textarea,
button,
picker {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
}

.section {
  margin-bottom: 24rpx;
  padding: 28rpx;
  background: #ffffff;
  border: 1rpx solid #e3ece4;
  border-radius: 8rpx;
}

.section-title {
  margin-bottom: 20rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #1e3a2b;
}

.muted {
  color: #6f7c72;
  font-size: 26rpx;
}

.field {
  margin-bottom: 22rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #405247;
  font-size: 26rpx;
}

.input,
.textarea,
.picker {
  width: 100%;
  min-height: 76rpx;
  padding: 18rpx 20rpx;
  background: #f8faf8;
  border: 1rpx solid #dce7de;
  border-radius: 8rpx;
  color: #1f2d24;
  font-size: 28rpx;
}

.textarea {
  min-height: 124rpx;
}

.primary-btn {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 8rpx;
  background: #26734d;
  color: #ffffff;
  font-size: 30rpx;
}

.secondary-btn {
  height: 76rpx;
  line-height: 76rpx;
  border: 1rpx solid #bdd4c4;
  border-radius: 8rpx;
  background: #ffffff;
  color: #26734d;
  font-size: 28rpx;
}

.danger-btn {
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 8rpx;
  background: #f8e7e4;
  color: #a23b2a;
  font-size: 26rpx;
}
